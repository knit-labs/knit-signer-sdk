{
  "name": "@useknit/signer-sdk",
  "version": "0.1.0",
  "description": "Browser-side helpers for registering and signing with Knit-managed signers (WebAuthn passkeys today; EOA + more later).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit": "npm audit --omit=dev --audit-level=moderate",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "knit",
    "safe",
    "webauthn",
    "passkey",
    "signer",
    "custody",
    "ethereum",
    "smart-account"
  ],
  "author": {
    "name": "Knit Labs",
    "url": "https://useknit.io"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/knit-labs/knit-signer-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/knit-labs/knit-signer-sdk/issues"
  },
  "homepage": "https://github.com/knit-labs/knit-signer-sdk#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@safe-global/protocol-kit": "^7.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "happy-dom": "^20.9.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
